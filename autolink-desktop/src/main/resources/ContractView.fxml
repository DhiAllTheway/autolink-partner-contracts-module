<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.ContractController"
      spacing="15"
      style="-fx-padding: 20;">

    <Label text="Contracts" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <!-- 🔍 Search and Sort Controls -->
    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="searchField" promptText="Search by Content..."/>
        <ComboBox fx:id="sortComboBox" promptText="Sort Contracts"/>
        <Button text="Search" onAction="#handleSearch"/>
        <Button text="➕ Add Contract" onAction="#handleAddContract"/>
    </HBox>

    <!-- 📑 Contract Cards -->
    <FlowPane fx:id="cardContainer" hgap="20" vgap="20"/>

    <!-- ⏮️ Pagination -->
    <HBox spacing="10" alignment="CENTER">
        <Button text="Previous" onAction="#handlePreviousPage"/>
        <Button text="Next" onAction="#handleNextPage"/>
    </HBox>

    <!-- ➕ Add/Edit Contract Form -->
    <VBox spacing="10" visible="false" fx:id="contractForm">
        <TextField fx:id="companyNameField" promptText="Sender Company Name"/>
        <TextField fx:id="receiverNameField" promptText="Receiver Company Name"/>
        <TextArea fx:id="contentField" promptText="Contract Content" wrapText="true"/>
        <Button text="Save" onAction="#handleSaveContract"/>
        <Button text="Cancel" onAction="#handleCancel"/>
    </VBox>

</VBox>
