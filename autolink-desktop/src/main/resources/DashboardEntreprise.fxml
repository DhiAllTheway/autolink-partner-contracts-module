<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="mainBorderPane" prefHeight="718.0" prefWidth="1300.0" styleClass="borderPane" stylesheets="@styles/style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.DashboardEntreprise">

    <left>
        <VBox fx:id="sideBar" prefHeight="890.0" prefWidth="235.0" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER" prefHeight="100.0" prefWidth="235.0">
                    <children>
                        <ImageView fitHeight="105.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/logo.jpg" />
                            </image>
                        </ImageView>
                    </children>
                    <VBox.margin>
                        <Insets bottom="20.0" />
                    </VBox.margin>
                </HBox>

                <VBox alignment="CENTER" prefHeight="311.0" prefWidth="260.0" spacing="15.0">
                    <children>
                        <!-- List Entreprise Button -->
                        <Button fx:id="blogBtn" alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="39.0" prefWidth="226.0" text="List entreprise" textFill="WHITE">
                            <graphic>
                                <ImageView fitHeight="25.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@icons/listEntreprise.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                            <font>
                                <Font size="20.0" />
                            </font>
                        </Button>

                        <!-- Partners Button -->
                        <Button fx:id="transportBtn" alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="39.0" prefWidth="240.0" text="Partenaires" textFill="WHITE">
                            <graphic>
                                <ImageView fitHeight="25.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@icons/Partners.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                            <font>
                                <Font size="20.0" />
                            </font>
                        </Button>
                  <Button fx:id="transportBtn1" alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="39.0" prefWidth="240.0" text="Contracts" textFill="WHITE">
                     <graphic>
                        <ImageView fitHeight="25.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@icons/Partners.png" />
                           </image>
                        </ImageView>
                     </graphic>
                     <font>
                        <Font size="20.0" />
                     </font>
                  </Button>
                    </children>
                </VBox>

                <VBox alignment="CENTER" prefHeight="59.0" prefWidth="235.0">
                    <children>
                        <Button fx:id="accountBtn" alignment="CENTER" mnemonicParsing="false" prefHeight="52.0" prefWidth="190.0" text="  Compte" textFill="WHITE">
                            <graphic>
                                <ImageView fx:id="accountImg" fitHeight="25.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@icons/compte.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                            <font>
                                <Font size="20.0" />
                            </font>
                        </Button>
                    </children>
                    <padding>
                        <Insets top="165.0" />
                    </padding>
                </VBox>
            </children>
            <BorderPane.margin>
                <Insets bottom="10.0" left="10.0" />
            </BorderPane.margin>
        </VBox>
    </left>
</BorderPane>
