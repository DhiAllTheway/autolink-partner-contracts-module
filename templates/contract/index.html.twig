{% extends 'base.html.twig' %}

{% block title %}Contracts{% endblock %}

{% block stylesheets %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .contracts-container {
            max-width: 900px;
            margin: 30px auto;
            padding: 20px;
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }

        h1 {
            text-align: center;
            margin-bottom: 20px;
        }

        .table th, .table td {
            vertical-align: middle;
            text-align: center;
        }

        .btn-sm {
            margin: 3px;
        }

        .status-pending {
            color: orange;
        }

        .status-accepted {
            color: green;
        }

        .status-rejected {
            color: red;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container contracts-container">
    <h1>Contracts</h1>

    <div class="text-end mb-3">
        <a href="{{ path('contracts_new') }}" class="btn btn-primary">+ Add Contract</a>
    </div>

    <!-- Sent Contracts Section -->
    <h2 class="mt-4">Sent Contracts</h2>
    <table class="table table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Receiver</th>
                <th>Content</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for contract in sentContracts %}
                <tr>
                    <td>{{ contract.receiver.companyName }}</td>
                    <td>{{ contract.content }}</td>
                    <td class="status-{{ contract.status|lower }}">
                        {% if contract.status == 'pending' %}
                            Pending
                        {% elseif contract.status == 'accepted' %}
                            Accepted
                        {% elseif contract.status == 'rejected' %}
                            Rejected
                        {% endif %}
                    </td>
                    <td>
                        <a href="{{ path('contracts_edit', {'id': contract.id}) }}" class="btn btn-warning btn-sm">Edit</a>
                        <form action="{{ path('contracts_delete', {'id': contract.id}) }}" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this contract?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ contract.id) }}">
                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center text-muted">No sent contracts found.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <!-- Received Contracts Section -->
    <h2 class="mt-5">Received Contracts</h2>
    <table class="table table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Sender</th>
                <th>Content</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for contract in receivedContracts %}
                <tr>
                    <td>{{ contract.entreprise.companyName }}</td>
                    <td>{{ contract.content }}</td>
                    <td class="status-{{ contract.status|lower }}">
                        {% if contract.status == 'pending' %}
                            Pending
                        {% elseif contract.status == 'accepted' %}
                            Accepted
                        {% elseif contract.status == 'rejected' %}
                            Rejected
                        {% endif %}
                    </td>
                    <td>
                        <!-- Accept Button for Received Contracts -->
                        <form action="{{ path('contracts_accept', {'id': contract.id}) }}" method="post" style="display:inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('accept' ~ contract.id) }}">
                            <button type="submit" class="btn btn-success btn-sm">Accept</button>
                        </form>

                        <!-- Reject (Delete) Button for Received Contracts -->
                        <form action="{{ path('contracts_reject', {'id': contract.id}) }}" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to reject this contract?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ contract.id) }}">
                            <button type="submit" class="btn btn-danger btn-sm">Reject</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center text-muted">No received contracts found.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
