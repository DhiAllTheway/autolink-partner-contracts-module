{% extends 'base.html.twig' %}

{% block title %}Edit Contract{% endblock %}

{% block stylesheets %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .contract-container {
            max-width: 600px;
            margin: 30px auto;
            padding: 20px;
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }

        h1 {
            text-align: center;
            margin-bottom: 20px;
        }

        .btn-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 15px;
        }

        .delete-form {
            display: inline;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container contract-container">
    <h1>Edit Contract</h1>

    {{ include('contract/_form.html.twig', {'button_label': 'Update'}) }}

    <div class="btn-container">
        <a href="{{ path('contracts_index') }}" class="btn btn-secondary">Back to List</a>
        
        {{ include('contract/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}