{% extends 'base.html.twig' %}

{% block title %}Liste des Articles{% endblock %}

{% block body %}
    <section class="product spad">
        <div class="container">
            <div class="row">
                <div class="col-lg-3 col-md-5">
                    <div class="sidebar">
                        <div class="sidebar__item">
                            <h4>Catégorie</h4>
                            <ul>
                                <li><a href="{{ path('app_listarticle') }}" class="btn btn-primary btn-small">All</a></li>
                                <li><a href="{{ path('list_article_by_categorie', {'category': 'Echappement'}) }}">Echappement</a></li>
                                <li><a href="{{ path('list_article_by_categorie', {'category': 'Electronique'}) }}">Electronique</a></li>
                                <li><a href="{{ path('list_article_by_categorie', {'category': 'Freinage'}) }}">Freinage</a></li>
                                <li><a href="{{ path('list_article_by_categorie', {'category': 'Pièces de carrosserie'}) }}">Pièces de carrosserie</a></li>
                                <li><a href="{{ path('list_article_by_categorie', {'category': 'Roues et pneumatique'}) }}">Roues et pneumatique</a></li>
                            </ul>
                        </div>

                       <div class="sidebar">
                            <div class="blog__sidebar__search">
                                <form method="GET" action="{{ path('article_index') }}">
                                    <input type="text" name="nom_article" placeholder="Rechercher par nom d'article...">
                                    <button type="submit"><span class="icon_search"></span></button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-9 col-md-7">
                    <div class="product__discount">
                        <div class="section-title product__discount__title">
                            <h2>Les pièces recyclées</h2>
                        </div>
                        <div class="row">
                            {% for article in articles %}
                                <div class="col-lg-4 col-md-6 col-sm-6">
                                    <div class="product__item">
                                        <div class="product__item__pic set-bg" style="background-image: url('{{ asset('img/product/' ~ article.image) }}');">
                                            <ul class="product__item__pic__hover">
                                                <li><a href="http://127.0.0.1:8000/details/{{article.id }}"><i class="fa fa-retweet"></i></a></li>
                                               <li>
                                                   <a href="{{ path('add_to_favorie', {'id': article.id}) }}" class="add-to-favorie">
                                                        <i class="fa fa-heart"></i>
                                                   </a>
                                                </li>
                                               <li>
                                                    <a href="#" class="add-to-cart">
                                                        <i class="fa fa-shopping-cart"></i>
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                        <div class="product__item__text">
                                            <h6>{{ article.getNom() }}</h6>
                                            <h5>${{ article.getprix() }}</h5>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
