<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Tableau de Bord Entreprise - Autolink</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    <style>
        .navbar-custom { background-color: #8B0000 !important; }
        .sidebar {
            height: 100vh;
            width: 250px;
            position: fixed;
            top: 0;
            left: 0;
            background-color: #343a40;
            padding-top: 20px;
        }
        .sidebar a {
            padding: 10px 15px;
            text-decoration: none;
            font-size: 18px;
            color: #fff;
            display: block;
        }
        .sidebar a:hover { background-color: #575757; }
        .sidebar a.active { background-color: #575757; }
        .main-content { margin-left: 250px; padding: 20px; }
        .partnership-management {
            background-color: #fff;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }
        .partnership-management h2 { margin-bottom: 20px; color: #8B0000; }
        .table th { background-color: #8B0000; color: #fff; }
        .status-pending { color: #ffc107; }
        .status-accepted { color: #28a745; }
        .status-rejected { color: #dc3545; }
        .btn-action { margin-right: 5px; }
    </style>
</head>
<body>

<div class="sidebar">
    <a href="{{ path('entreprise_dashboard') }}"
       {% if app.request.get('_route') == 'entreprise_dashboard' %}class="active"{% endif %}>
       <i class="fas fa-home"></i> Accueil
    </a>
    <a href="{{ path('partnership_request') }}"
       {% if app.request.get('_route') == 'partnership_request' %}class="active"{% endif %}>
       <i class="fas fa-file-contract"></i> Demandes de Partenariat
    </a>
    <a href="{{ path('contracts_index') }}"
       {% if app.request.get('_route') == 'contracts_index' %}class="active"{% endif %}>
       <i class="fas fa-file-contract"></i> Contrats
    </a>
    <a href="#"><i class="fas fa-cog"></i> Paramètres</a>
    <a href="{{ path('entreprise_logout') }}"><i class="fas fa-sign-out-alt"></i> Déconnexion</a>
</div>

<div class="main-content">
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container-fluid">
            <a class="navbar-brand text-white" href="#">Tableau de Bord Entreprise</a>
        </div>
    </nav>

    <h2>Toutes les Demandes de Partenariat</h2>

    {# Dynamic Search and Sort Form #}
    <form method="GET" id="filterForm" class="d-flex mb-3">
        <input
            type="text"
            name="search"
            value="{{ search|default('') }}"
            class="form-control me-2"
            placeholder="Rechercher par numéro de téléphone..."
            id="searchInput"
        >
        <select
            name="sort"
            class="form-select me-2"
            id="sortSelect"
        >
            <option value="">Filtrer par Type de Partenariat</option>
            {% for type in ['sponsoring', 'recycling', 'education', 'marketing'] %}
                <option value="{{ type }}"
                    {% if sort == type %}selected{% endif %}
                >
                    {{ type|capitalize }}
                </option>
            {% endfor %}
        </select>
    </form>

    {# Partnership Requests Table #}
    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Address</th>
                <th>Tax Code</th>
                <th>Type de Partenariat</th>
                <th>Description</th>
                <th>Date de Soumission</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for request in partnershipRequests %}
                <tr>
                    <td>{{ request.idRequest }}</td>
                    <td>{{ request.companyEmail }}</td>
                    <td>{{ request.phone }}</td>
                    <td>{{ request.address }}</td>
                    <td>{{ request.taxCode }}</td>
                    <td>{{ request.partnershipType }}</td>
                    <td>{{ request.description }}</td>
                    <td>{{ request.submittedAt|date('Y-m-d H:i:s') }}</td>
                    <td class="status-{{ request.status|lower }}">{{ request.status }}</td>
                    <td>
                        <a href="{{ path('partnership_request_edit', { 'id': request.idRequest }) }}"
                           class="btn btn-primary btn-sm">
                           Modifier
                        </a>

                        {# Form for delete action #}
                        <form method="post" action="{{ path('partnership_request_delete', { 'id': request.idRequest }) }}" 
                              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette demande ?');" style="display:inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ request.idRequest) }}">
                            <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                        </form>

                        <a href="{{ path('partnership_request_show', { 'id': request.idRequest }) }}"
                           class="btn btn-info btn-sm">
                           Voir
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="10" class="text-center">Aucune demande trouvée.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<script>
document.querySelector("#searchInput").addEventListener("keydown", function(event) {
    if (event.key === "Enter") {
        document.getElementById("filterForm").submit();
    }
});

document.querySelector("#sortSelect").addEventListener("change", function() {
    document.getElementById("filterForm").submit();
});
</script>

</body>
</html>
