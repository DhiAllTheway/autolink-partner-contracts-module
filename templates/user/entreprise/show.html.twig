<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Détails de la Demande de Partenariat</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .container { max-width: 800px; margin-top: 50px; }
        .card { padding: 20px; border-radius: 10px; box-shadow: 0 0 10px rgba(0, 0, 0, 0.1); }
        .card-title { color: #8B0000; }
        .qr-code { text-align: center; margin-top: 30px; }
        .qr-code img { width: 250px; height: 250px; border: 2px solid #000; padding: 5px; }
    </style>
</head>
<body>
<div class="container">
    <div class="card">
        <h2 class="card-title">Détails de la Demande de Partenariat</h2>
        <table class="table table-bordered">
            <tr><th>ID</th><td>{{ partnershipRequest.idRequest }}</td></tr>
            <tr><th>Email</th><td>{{ partnershipRequest.companyEmail }}</td></tr>
            <tr><th>Téléphone</th><td>{{ partnershipRequest.phone }}</td></tr>
            <tr><th>Adresse</th><td>{{ partnershipRequest.address }}</td></tr>
            <tr><th>Code Fiscale</th><td>{{ partnershipRequest.taxCode }}</td></tr>
            <tr><th>Type de Partenariat</th><td>{{ partnershipRequest.partnershipType }}</td></tr>
            <tr><th>Description</th><td>{{ partnershipRequest.description }}</td></tr>
            <tr><th>Date de Soumission</th><td>{{ partnershipRequest.submittedAt|date('Y-m-d H:i:s') }}</td></tr>
            <tr><th>Statut</th><td>{{ partnershipRequest.status }}</td></tr>
        </table>
    </div>

    <!-- Put the QR code block here, inside the body -->
    <div class="qr-code">
    <h4>QR Code de la Demande</h4>
    {% if qrCode %}
        <img src="{{ qrCode }}" alt="QR Code"
             style="width:250px; height:250px; border:2px solid #000; padding:5px;">
    {% else %}
        <p>Impossible de générer le QR Code.</p>
    {% endif %}
</div>




</div>
</body>
</html>
