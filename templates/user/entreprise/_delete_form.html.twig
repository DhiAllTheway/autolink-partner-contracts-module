<form method="post" action="{{ path('partnership_request_delete', { 'id': partnershipRequest.idRequest }) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette demande ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ partnershipRequest.idRequest) }}">
    <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
</form>
