{# templates/entreprise/register.html.twig #}
<!DOCTYPE html>
<html>
<head>
    <title>Create Account</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* Import the fonts */
        @import url('https://fonts.googleapis.com/css?family=Poppins:100,100i,200,200i,300,300i,400,400i,500,500i,600,600i,700,700i,800,800i,900,900i');
        @import url('https://fonts.googleapis.com/css?family=Rufina:400,700');

        body {
            background-image: url('/images/welcome-hero/welcome-banner.jpg'); /* Replace with your image path */
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Poppins', sans-serif;
            color: white;
        }

        .form-container {
            background-color: rgba(17, 17, 17, 0.9);
            padding: 3rem;
            border-radius: 10px;
            width: 100%;
            max-width: 500px;
        }

        h2 {
            display: flex;
            justify-content: center;
            color: #edb77d;
            font-family: 'Rufina', serif;
        }

        .form-label {
            width: 100%;
            display: block;
            color: #bebebe;
            font-family: 'Poppins', sans-serif;
        }

        .form-control {
            width: 100%;
            background-color: rgba(255, 255, 255, 0.1);
            color: white;
            border: 2px solid #999;
            border-radius: 10px;
            padding: 10px;
            font-family: 'Poppins', sans-serif;
        }

        .form-control:focus {
            border-color: #edb77d;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        .btn-primary {
            background-color: #edb77d;
            border-color: #edb77d;
            color: #111;
            border-radius: 10px;
            padding: 12px 21px;
            font-family: 'Poppins', sans-serif;
        }

        .btn-primary:hover {
            background-color: #e79e50;
            border-color: #e79e50;
        }

        .d-grid .btn-primary {
            border-radius: 10px;
        }

        .form-error {
            color: #ff6b6b;
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }

        .flash-messages {
            margin-bottom: 1.5rem;
        }

        .alert {
            padding: 0.75rem 1.25rem;
            border-radius: 10px;
            font-size: 0.875rem;
        }

        .alert-success {
            background-color: #d4edda;
            color: #155724;
            border-color: #c3e6cb;
        }

        .alert-danger {
            background-color: #f8d7da;
            color: #721c24;
            border-color: #f5c6cb;
        }
    </style>
</head>
<body>

<div class="row justify-content-center align-items-center" style="height: 100vh;">
    <div class="col-md-6">
        <div class="form-container">
            <h2 class="mb-4 text-center font-weight-bold">Create Account</h2>

            <div class="flash-messages">
                {% for type, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ type }}">{{ message }}</div>
                    {% endfor %}
                {% endfor %}
            </div>

            {{ form_start(form, {'attr': {'class': 'needs-validation'}}) }}

                {{ form_row(form.company_name) }}
                {{ form_row(form.field) }}
                {{ form_row(form.tax_code) }}
                {{ form_row(form.email) }}
                {{ form_row(form.password) }}
                {{ form_row(form.phone) }}
                {{ form_row(form.supplier) }}

                <h3>Address</h3>
                {{ form_row(form.address.street) }}
                {{ form_row(form.address.city) }}
                {{ form_row(form.address.postal_code) }}
                {{ form_row(form.address.country) }}

                <div class="d-grid">
                    {{ form_widget(form.submit, {'attr': {'class': 'btn btn-primary btn-lg'}}) }}
                </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>